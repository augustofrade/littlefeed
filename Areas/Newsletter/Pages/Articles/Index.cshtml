@page "/n/{newsletterSlug}/a/{articleSlug}"
@model LittleFeed.Areas.Newsletter.Pages.Articles.Index

@{
    Layout = "_Layout";
    var data = Model.Article;
    var publishDate = data.PublishDate.ToLocalTime().ToString("MMM dd, yyyy 'at' HH:mm");
}

<section class="mb-5 text-center pb-5">
    <div class="w-75 mx-auto mb-2">
        <h3 class="mb-0 h6">
            <a asp-page="/Details" asp-area="Newsletter" asp-route-slug="@data.Newsletter.Slug" class="text-decoration-hover text-reset">
                [@data.Newsletter.Name]
            </a>
        </h3>
        <h1 class="fw-bold mb-0">@data.Title</h1>
    </div>
    <div>
        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="currentColor" class="bi bi-newspaper" viewBox="0 0 16 16">
            <path d="M0 2.5A1.5 1.5 0 0 1 1.5 1h11A1.5 1.5 0 0 1 14 2.5v10.528c0 .3-.05.654-.238.972h.738a.5.5 0 0 0 .5-.5v-9a.5.5 0 0 1 1 0v9a1.5 1.5 0 0 1-1.5 1.5H1.497A1.497 1.497 0 0 1 0 13.5zM12 14c.37 0 .654-.211.853-.441.092-.106.147-.279.147-.531V2.5a.5.5 0 0 0-.5-.5h-11a.5.5 0 0 0-.5.5v11c0 .278.223.5.497.5z"/>
            <path d="M2 3h10v2H2zm0 3h4v3H2zm0 4h4v1H2zm0 2h4v1H2zm5-6h2v1H7zm3 0h2v1h-2zM7 8h2v1H7zm3 0h2v1h-2zm-3 2h2v1H7zm3 0h2v1h-2zm-3 2h2v1H7zm3 0h2v1h-2z"/>
        </svg>
    </div>
    <div class="text-muted">
        <span class="d-block">
            By
            <a asp-page="Users"
               asp-route-userProfileSlug="@data.Author.Slug"
               class="fw-bold text-black text-decoration-hover">@data.Author.Name</a>
        </span>
        <span class="d-block">
            @publishDate
        </span>
    </div>
</section>

<section>
    @Html.Raw(data.Body)
</section>
