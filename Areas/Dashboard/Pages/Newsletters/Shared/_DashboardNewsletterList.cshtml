@model List<LittleFeed.Dto.Newsletters.ListOwnedNewsletterDto>

@if (Model.Count == 0)
{
    <div class="alert alert-info">
        No newsletters found
    </div>    
}
else
{
    <ul style="list-style: none;">
        @{
            var count = Model.Count;
            for (var index = 0; index < count; index++)
            {
                var newsletter = Model.ElementAt(index);
                <li>
                    <article onclick="location.href='@Url.PageLink("/Newsletters/Manage", values: new { area = "Dashboard", slug=@newsletter.Slug })'"
                             class="text-decoration-none d-flex justify-content-between align-items-center px-3 py-4 rounded-2 clickable-list-item">
                        <div>
                            <span class="h4 d-block text-secondary fw-bold">@newsletter.Name</span>
                            <div class="d-flex align-items-center gap-4">
                                <span class="text-muted">@newsletter.CreatedAt.ToLocalTime().ToShortDateString()</span>
                                <span class="badge bg-primary">Category</span>
                            </div>
                        </div>
                        <div class="d-flex gap-2">
                            <a class="btn btn-outline-primary btn-sm" asp-area="Dashboard" asp-page="/Newsletters/Articles/Write" asp-route-newsletterSlug="@newsletter.Slug">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-plus" viewBox="0 0 16 16">
                                    <path d="M8 4a.5.5 0 0 1 .5.5v3h3a.5.5 0 0 1 0 1h-3v3a.5.5 0 0 1-1 0v-3h-3a.5.5 0 0 1 0-1h3v-3A.5.5 0 0 1 8 4"/>
                                </svg>
                                Write Post
                            </a>
                            <a class="btn btn-light btn-sm" asp-area="Newsletter" asp-page="/Details" asp-route-slug="@newsletter.Slug">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-eye-fill" viewBox="0 0 16 16">
                                    <path d="M10.5 8a2.5 2.5 0 1 1-5 0 2.5 2.5 0 0 1 5 0"/>
                                    <path d="M0 8s3-5.5 8-5.5S16 8 16 8s-3 5.5-8 5.5S0 8 0 8m8 3.5a3.5 3.5 0 1 0 0-7 3.5 3.5 0 0 0 0 7"/>
                                </svg>
                                View
                            </a>
                            @if (newsletter.IsOwner)
                            {
                                <a class="btn btn-light btn-sm" asp-area="Dashboard" asp-page="/Newsletters/Manage" asp-route-slug="@newsletter.Slug">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-pencil-fill" viewBox="0 0 16 16">
                                        <path d="M12.854.146a.5.5 0 0 0-.707 0L10.5 1.793 14.207 5.5l1.647-1.646a.5.5 0 0 0 0-.708zm.646 6.061L9.793 2.5 3.293 9H3.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.207zm-7.468 7.468A.5.5 0 0 1 6 13.5V13h-.5a.5.5 0 0 1-.5-.5V12h-.5a.5.5 0 0 1-.5-.5V11h-.5a.5.5 0 0 1-.5-.5V10h-.5a.5.5 0 0 1-.175-.032l-.179.178a.5.5 0 0 0-.11.168l-2 5a.5.5 0 0 0 .65.65l5-2a.5.5 0 0 0 .168-.11z"/>
                                    </svg>
                                    Manage
                                </a>
                            }
                        </div>
                    </article>
                </li>
            }
        }
    </ul>
}
