@page "/Dashboard/Newsletters/{newsletterSlug}/Articles/Write"
@model LittleFeed.Areas.Dashboard.Pages.Newsletters.Articles.Write

@{
    Layout = "_Layout";
}
    
<section class="mb-4 d-flex align-items-center justify-content-between">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-area="Dashboard" asp-page="/Newsletters/Manage" asp-route-slug="@Model.NewsletterSlug">@Model.NewsletterName</a></li>
            <li class="breadcrumb-item active" aria-current="page">New Article</li>
        </ol>
    </nav>
    
    <div>
        <button class="btn btn-light btn-sm me-1">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-vector-pen" viewBox="0 0 16 16">
                <path fill-rule="evenodd" d="M10.646.646a.5.5 0 0 1 .708 0l4 4a.5.5 0 0 1 0 .708l-1.902 1.902-.829 3.313a1.5 1.5 0 0 1-1.024 1.073L1.254 14.746 4.358 4.4A1.5 1.5 0 0 1 5.43 3.377l3.313-.828zm-1.8 2.908-3.173.793a.5.5 0 0 0-.358.342l-2.57 8.565 8.567-2.57a.5.5 0 0 0 .34-.357l.794-3.174-3.6-3.6z"/>
                <path fill-rule="evenodd" d="M2.832 13.228 8 9a1 1 0 1 0-1-1l-4.228 5.168-.026.086z"/>
            </svg>
            Save as draft
        </button>
        <button class="btn btn-success btn-sm">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-newspaper" viewBox="0 0 16 16">
                <path d="M0 2.5A1.5 1.5 0 0 1 1.5 1h11A1.5 1.5 0 0 1 14 2.5v10.528c0 .3-.05.654-.238.972h.738a.5.5 0 0 0 .5-.5v-9a.5.5 0 0 1 1 0v9a1.5 1.5 0 0 1-1.5 1.5H1.497A1.497 1.497 0 0 1 0 13.5zM12 14c.37 0 .654-.211.853-.441.092-.106.147-.279.147-.531V2.5a.5.5 0 0 0-.5-.5h-11a.5.5 0 0 0-.5.5v11c0 .278.223.5.497.5z"/>
                <path d="M2 3h10v2H2zm0 3h4v3H2zm0 4h4v1H2zm0 2h4v1H2zm5-6h2v1H7zm3 0h2v1h-2zM7 8h2v1H7zm3 0h2v1h-2zm-3 2h2v1H7zm3 0h2v1h-2zm-3 2h2v1H7zm3 0h2v1h-2z"/>
            </svg>
            Publish
        </button>
    </div>
</section>

<section class="mb-4">
    <input type="text" class="form-control border-top-0 border-0 rounded-0 border-bottom fs-2" placeholder="New Article Title">
</section>

<section>
    <div id="article-editor"></div>
</section>

@section Styles {
    <link href="https://cdn.jsdelivr.net/npm/summernote@0.9.0/dist/summernote-bs5.min.css" rel="stylesheet">
    <style>
        .note-frame {
            border: none !important;
        }

        .note-toolbar {
            background: none !important;
        }

        .note-editing-area {
            padding:  20px;
        }

        .note-resizebar {
            display: none;
        }

        .note-statusbar {
            border-top: none !important;
        }
    </style>
    
    
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/summernote@0.9.0/dist/summernote-bs5.min.js"></script>
    <script>
        $(document).ready(function() {
            $("#article-editor").summernote({
                height: 500,
                minHeight: 500,
                maxHeight: 500,
                focus: true,
                styleTags: [
                    'p',
                    { title: 'Blockquote', tag: 'blockquote', className: 'blockquote', value: 'blockquote' },
                    'pre', 'h1', 'h2', 'h3', 'h4', 'h5', 'h6'
                ],
                toolbar: [
                    ["style", ["style"]],
                    ["font", ["bold", "italic", "underline", "strikethrough"]],
                    ["para", ["ul", "ol", "paragraph"]],
                    ["table", ["table"]],
                    ["insert", ["link", "picture", "hr"]],
                    ["view", ["undo", "redo", "help"]]
                ],
                placeholder: "Hello from new article!"
            });
        });
    </script>
}
