@model LittleFeed.Dto.Articles.ListArticleDto

@{
    var publishDateTime = Model.PublishDate.ToLocalTime();
    var publishDate = publishDateTime.ToShortDateString();
    var publishTime = publishDateTime.ToShortTimeString();
}

<a asp-area="Newsletter" asp-page="/Articles/Index" asp-route-newsletterSlug="@Model.NewsletterSlug" asp-route-articleSlug="@Model.Slug"
   class="text-decoration-none">
    <article class="d-flex justify-content-between align-items-center px-4 py-2 rounded-2 clickable-list-item">
        <div>
            <span class="h4 d-block text-secondary fw-bold fs-5">@Model.Title</span>
            <div class="d-flex align-items-center gap-4">
                <span class="text-muted">@publishDate at @publishTime</span>
            </div>
        </div>
    </article>
</a>
